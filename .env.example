# Default is safe. Live trading requires LIVE_TRADING=true plus config confirmation.
LIVE_TRADING=false

# Alpaca paper/live credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Binance credentials
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Coinbase Advanced Trade credentials
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_KEY_FILE=

# Interactive Brokers placeholder settings
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# Fidelity is intentionally disabled unless backed by an official/contracted API.
FIDELITY_OFFICIAL_API_ENABLED=false
